# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Prisma (Supabase Postgres) — used by prisma.config.ts for the CLI/migrations
# and by PrismaClient at runtime. Get these from your Supabase project's
# Database settings -> Connection string.
# Transaction-mode pooler (IPv4-only, port 6543) — used at runtime.
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Session-mode pooler (port 5432) — used for migrations, which need a direct,
# non-pgbouncer connection.
DIRECT_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin dashboard
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_WHATSAPP_NUMBER=27xxxxxxxxxx
ADMIN_EMAIL=admin@yourdomain.com

# Session signing secret — REQUIRED. Signs the admin and vendor session JWTs.
# Must be a long, random string (min 16 chars; 32+ recommended). Authentication
# fails closed if this is unset. Generate one with: openssl rand -base64 32
SESSION_SECRET=generate_a_long_random_string

# Email notifications (Resend — free at resend.com, 3 000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# WhatsApp Cloud API (see /guide/whatsapp-setup for setup steps)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose_any_random_string
# App Secret from your Meta App's Settings -> Basic page. Used only to verify
# the X-Hub-Signature-256 header on inbound webhook requests — never sent in
# any outbound API call. Without this set, the webhook rejects all messages.
WHATSAPP_APP_SECRET=your_meta_app_secret

# Approved WhatsApp message-template names (create + get approved in Meta Business
# Manager first — see docs/whatsapp-automation-scale.md). When set, business-
# initiated notifications send as templates so they deliver even outside the 24h
# customer-service window. When unset, the app falls back to free-form text
# (fine for dev or within the 24h window). Optional.
WHATSAPP_TEMPLATE_REFERRAL_WON=
WHATSAPP_TEMPLATE_OVERRIDE_EARNED=
